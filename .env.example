# Скопируй этот файл в .env и заполни значения
# ВАЖНО: файл .env никогда не коммить в git — там секретные данные

# Секретный ключ Flask. Используется для защиты сессий и форм.
# Придумай длинную случайную строку, например: openssl rand -hex 32
SECRET_KEY=change-me-to-something-random-and-long

# Окружение: development (разработка) или production (продакшен)
FLASK_ENV=development

# URL базы данных.
# Для разработки SQLite — просто имя файла.
# Для продакшена PostgreSQL — например: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///astroshare_dev.db

# NASA API ключ. Получи бесплатно на https://api.nasa.gov
# DEMO_KEY работает, но имеет ограничения по количеству запросов
NASA_API_KEY=DEMO_KEY

# ── Настройки почты (для подтверждения email и сброса пароля) ──
# Если MAIL_USERNAME не задан — письма выводятся в консоль (режим разработки)
#
# Для Gmail:
#   1. Включи двухэтапную аутентификацию: myaccount.google.com → Безопасность
#   2. Создай "Пароль приложения": myaccount.google.com → Безопасность → Пароли приложений
#   3. Вставь полученный 16-значный пароль в MAIL_PASSWORD
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=your-email@gmail.com
